%dw 2.0

fun mapStore(code) = code match {
	case "HMB CAMINHO - PIRACICABA" -> "Hyundai - Piracicaba" 
	case  "HMB CAMINHO - LIMEIRA" -> "Hyundai - Limeira"
	case "FORD AUTOMOVEIS ARAÇATUBA" -> "Ford - Araçatuba"
	case "FORD AUTOMOVEIS PRUDENTE" -> "Ford - P. Prudente"
	case "FORD AUTOMOVEIS BAURU" -> "Ford - Bauru"
	case "FORD AUTOMOVEIS RIO PRETO" -> "Ford - SJRP"
	case "FORD AUTOMOVEIS AMERICANA" -> "Ford - Americana"
	case "FORD AUTOMOVEIS PIRACICABA" -> "Ford - Piracicaba"
	case "FORD AUTOMOVEIS CAMPINAS" -> "Ford - Campinas"
	case "FORD AUTOMOVEIS MARILIA" -> "Ford - Marília"
	case "HMB CAMINHO - CATANDUVA" -> "Hyundai - Catanduva"
	case "FIAT CAMINHO ARAÇATUBA" -> "Fiat - Araçatuba"
	case "FIAT CAMINHO VOTUPORANGA" -> "Fiat - Votuporanga"
	case "RAM CAMINHO ARAÇATUBA" -> "RAM - Araçatuba"
	case "DAF CAMINHO ARAÇATUBA" -> "DAF - Araçatuba"
	case "DAF CAMINHO ARARAQUARA" -> "DAF - Araraquara"
	case "DAF CAMINHO RIBEIRÃO PRETO" -> "DAF - Ribeirão Preto"
	case "DAF CAMINHO RIO PRETO" -> "DAF - SJRP"
	case "O J CAMINHO PIRACICABA" -> "OMODA/JAECOO - Piracicaba"
	case "FIAT CAMINHO VOTUPORANGA - OFI" -> "Fiat - Votuporanga - Oficina"
	case "FORD CAMINHÕES ARAÇATUBA" -> "Ford - Caminhões - Araçatuba"
	case "FORD CAMINHÕES RIO PRETO" -> "Ford - Caminhões - Rio Preto"
	case "DEPOSITO FORD ARAÇATUBA" -> "Ford - Deposito - Araçatuba"
	case "DEPOSITO FORD PIRACICABA" -> "Ford - Deposito - Piracicaba"
	case "DEPOSITO FORD PIRACICABA 2" -> "Ford - Deposito - Piracicaba 2"
	case "DEPOSITO FORD RIO PRETO" -> "Ford - Deposito - Rio Preto"
	case "DEPOSITO FIAT ARAÇATUBA" -> "Fiat - Araçatuba - Deposito"
	case "DEPOSITO FIAT VOTUPORANGA" -> "Fiat - Votuporanga - Deposito"
	case "CENTRALIZADORA" -> "Centralizadora"
}

fun mapAppointmentType(code) = code match {
	case "Internet" -> "I" 
	case  "Receptivo" -> "R"
	case "Presencial" -> "P"
	case "Atendido" -> "T"
	case "Complemento" -> "C"
	case "Em pedido" -> "E"
	case "On Star" -> "M"
	case "Ativo" -> "A"
}