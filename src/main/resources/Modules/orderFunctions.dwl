fun mapAppointmentType(code) = code match {
	case "Internet" -> "I" 
	case  "Receptivo" -> "R"
	case "Presencial" -> "P"
	case "Atendido" -> "T"
	case "Complemento" -> "C"
	case "Em pedido" -> "E"
	case "On Star" -> "O"
	case "Ativo" -> "A"
}

fun mapAppointmentTypeReversed(code) = code match {
	case "I" -> "Internet" 
	case  "R" -> "Receptivo"
	case "P" -> "Presencial"
	case "A" -> "Atendido"
	case "C" -> "Complemento"
	case "E" -> "Em pedido"
	case "T" -> "On Star"
	case "1" -> "Ativo"
}

