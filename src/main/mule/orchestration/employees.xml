		<flow-ref doc:name="search-recordType-salesforce" doc:id="22ee7e2c-24e6-4704-ab2a-5b0d52d5511c" name="search-recordType-salesforce" target="rTypeCons" />
		<flow-ref doc:name="get-employees-scheduling-status" doc:id="7c4dfe88-6086-436d-b814-61017d25147e" name="get-employees-scheduling-status" />
		<choice doc:name="Choice" doc:id="f6467f2a-da51-4283-8942-485934597bd1" >
			<when expression="#[sizeOf(payload) &gt; 0]">
				<ee:transform doc:name="Variable to Create OS Line Items" doc:id="813bafcd-817c-455e-86b7-0605608d0a9a">
			<ee:message />
			<ee:variables>
				<ee:set-variable variableName="vPayload"><![CDATA[%dw 2.0
output application/json
---
payload ]]></ee:set-variable>
				<ee:set-variable variableName="lineCodes"><![CDATA[%dw 2.0
output application/json
---
payload.codigoIdServico]]></ee:set-variable>
				<ee:set-variable variableName="arrayLine"><![CDATA[%dw 2.0
output application/json
---
[]]]></ee:set-variable>
			</ee:variables>
		</ee:transform>
				<foreach doc:name="For Each" doc:id="e0cdbf33-921d-49e9-b9b0-46983c097036">
			<ee:transform doc:name="TMO ExternalId" doc:id="e8e9a851-e39c-4237-9f76-e0ad24d0a47a">
				<ee:message>
				</ee:message>
				<ee:variables>
					<ee:set-variable variableName="TMOExternalId"><![CDATA[%dw 2.0
output application/json
---
if(!isBlank(payload.modeloVeiculoTmoTempo)) 
(payload.codigoTMO ++ "_" ++ payload.modeloVeiculoTmoTempo)
else 
payload.codigoTMO]]></ee:set-variable>
				</ee:variables>
			</ee:transform>
			<ee:transform doc:name="Map Payload to Create OS Line Items" doc:id="6494c010-497a-4b5b-92f7-39183f61e7ab">
				<ee:message>
					<ee:set-payload><![CDATA[%dw 2.0
import * from Modules::orderFunctions
output application/json
---
[{
	attributes: {
		"type": "WorkOrderLineItem"
	},
    ExternalId__c: payload.codigoIdServico, //vars.TMOExternalId ++ "_" ++ '
    DurationTime__c: (payload.duracaoServico/3600) as String,
    TmoExecutes__c: payload.executa,
    TmoRequiresTest__c: payload.exigeTesteVeiculo,
    TmoPrioritario__c: payload.prioritario default false,
    ExpressReview__c: payload.servicoRapido,
    TmoCharges__c: payload.cobra,
    ExecutionSector__c: mapExecSec(payload.setorExecucao),
    Quantity: payload.quantidadeTMO,
    Discount: payload.percDesconto,
    DiscountValue__c: payload.valorDesconto,
    Classification__c: payload.classificacaoTipoOs,
    WorkOrder: if(!isBlank(payload.codigoAgendamento)) {
    	SchedulingExternalId__c: payload.codigoAgendamento
    } 
    else
    {
    	ExternalId__c: payload.codigoOS
    },
    WorkOrderType__r: {
        ExternalId__c: payload.codigoTipoOs
    },
    UnitPrice: payload.valorUnitario,
    PricebookEntry: {
        ExternalId__c: "WorkOrderTMO" ++ "_" ++ vars.TMOExternalId
    }
}]]]></ee:set-payload>
				</ee:message>
				<ee:variables>
				</ee:variables>
			</ee:transform>
			<ee:transform doc:name="Concat Payload" doc:id="a8daf1e2-3380-49c6-886a-f78a72fed09a">
				<ee:message>
				</ee:message>
				<ee:variables>
					<ee:set-variable variableName="arrayLine"><![CDATA[%dw 2.0
output application/java
---
vars.arrayLine ++ payload]]></ee:set-variable>
				</ee:variables>
			</ee:transform>
		</foreach>
				<ee:transform doc:name="Payload to Send LineItems" doc:id="015e93c6-91d8-4aa6-a180-836fd3d1bfa3">
			<ee:message>
				<ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
	allOrNone: false,
	records: vars.arrayLine
}]]></ee:set-payload>
			</ee:message>
		</ee:transform>
				<flow-ref doc:name="send-os-lineItems-to-salesforce" doc:id="8afb5dcc-e8bc-4596-b1d8-c9a9e673e0dd" name="send-os-lineItems-to-salesforce" />
				<logger level="INFO" doc:name="Logger" doc:id="7ffebb0a-f238-4097-8eb0-ddd91f2722ab" message="#[%dw 2.0&#10;output application/json&#10;---&#10;payload map (value, index) -&gt; if(value.success == true)&#10;{&#10;    idLineItem: vars.lineCodes[(index)],&#10;    sfId: value.id&#10;}&#10;else &#10;{&#10;    idLineItem: vars.lineCodes[(index)],&#10;    description: value.errors[0].message&#10;}]" />
				<flow-ref doc:name="employees-scheduling-batch" doc:id="981581ea-7f6b-4f1c-8728-2ddce67e29ad" name="employees-scheduling-batch" />
			</when>
			<otherwise >
				<logger level="INFO" doc:name="Logger Empty" doc:id="3985873a-c0e9-466f-b837-b6071fea3032" message="Não foi encontrado nenhum agendamento de produtivo(a) criado ou alterado no Dealernet"/>
			</otherwise>
		</choice>
	</sub-flow>
