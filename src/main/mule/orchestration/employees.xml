"scheduling__c"]]></ee:set-variable>
				<ee:set-variable variableName="name"><![CDATA[%dw 2.0
output application/json
---
"Consultor"]]></ee:set-variable>
						<ee:set-variable variableName="company"><![CDATA[%dw 2.0
output application/json
---
attributes.queryParams.company]]></ee:set-variable>
			</ee:variables>
		</ee:transform>
		<flow-ref doc:name="search-recordType-salesforce" doc:id="99fb1e36-63f5-42d8-8fa8-6f43a920784a" name="search-recordType-salesforce" target="rTypeCons" />
		<flow-ref doc:name="get-employees-scheduling-status" doc:id="7401a2ae-6b1e-4399-8dc5-2bf2787e754f" name="get-employees-scheduling-status" />
		<choice doc:name="Choice" doc:id="d66a65ba-b824-4c2f-bdcb-c27c4e35bae1" >
			<when expression="#[sizeOf(payload) &gt; 0]">
				<ee:transform doc:name="Variable to Create OS" doc:id="ecf51b2a-ecc1-4a4f-bd38-b12355f2f42b">
			<ee:message>
			</ee:message>
			<ee:variables>
				<ee:set-variable variableName="vPayload"><![CDATA[%dw 2.0
output application/json
---
payload //filter !isBlank($.nomeConsultor)]]></ee:set-variable>
				<ee:set-variable variableName="arrayOS"><![CDATA[%dw 2.0
output application/json
---
[]]]></ee:set-variable>
				<ee:set-variable variableName="osCodes"><![CDATA[%dw 2.0
output application/json
---
payload.codigoAgendamento]]></ee:set-variable>
			</ee:variables>
		</ee:transform>
				<foreach doc:name="For Each" doc:id="773b3058-c18b-4ebb-80ac-6f4b079d8895">
			<ee:transform doc:name="Map Payload to Create OS" doc:id="43da1072-d5a3-4b5f-b74e-960906d0d939">
				<ee:message>
					<ee:set-payload><![CDATA[%dw 2.0
import * from Modules::orderFunctions
output application/json
---
[{
		attributes: {
			"type": "WorkOrder"
		},
		Asset: {
			ExternalId__c: payload.codigoVeiculo
		},
		Type__c: mapAppointmentTypeReversed(payload.tipoAgendamento),
		CurrentMileage__c: payload.km,
		ExternalId__c: payload.codigoOs,
		SchedulingExternalId__c: payload.codigoAgendamento,
		Status: "Agendamento realizado",
		CustomerNeedsTransport__c:  payload.clienteDesejaTransporte default false,
		CustomerWaiting__c: payload.clienteAguarda default false,
		ExpressService__c: payload.servicoExpresso default false,
		LiftInspection__c: payload.inspecaoElevador default false,
		//ProcessPhase__c: payload.partSequence,
		RequiresWashing__c: payload.exigeLavagem default false,
		ValetService__c: payload.servicoValet default false,
		Account: {
			ExternalId__c: payload.codigoCliente
		},
		Store__r: {
			ExternalId__c: mapStore2(payload.codigoLoja)
		}
	}]
]]></ee:set-payload>
				</ee:message>
				<ee:variables>
				</ee:variables>
			</ee:transform>
			<ee:transform doc:name="Concat Payload" doc:id="1e0ea397-2794-4b58-a25d-abe44e85886c">
				<ee:message>
				</ee:message>
				<ee:variables>
					<ee:set-variable variableName="arrayOS"><![CDATA[%dw 2.0
output application/json
---
vars.arrayOS ++ payload]]></ee:set-variable>
				</ee:variables>
			</ee:transform>
		</foreach>
				<ee:transform doc:name="Payload to Send OS" doc:id="d105f490-c659-4eda-83fd-edd42c9de194">
			<ee:message>
				<ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
	allOrNone: false,
	records: vars.arrayOS
}]]></ee:set-payload>
			</ee:message>
		</ee:transform>
				<flow-ref doc:name="send-os-status-to-salesforce" doc:id="574407ab-804f-4f17-abb8-069e843e927f" name="send-os-status-to-salesforce" />
				<logger level="INFO" doc:name="Logger" doc:id="4fea2aee-541e-4c5a-a51b-aa211d6407e7" message="#[%dw 2.0&#10;output application/json&#10;---&#10;payload map (value, index) -&gt; if(value.success == true)&#10;{&#10;    idOS: vars.osCodes[(index)],&#10;    sfId: value.id&#10;}&#10;else &#10;{&#10;    idOS: vars.osCodes[(index)],&#10;    description: value.errors[0].message&#10;}]" />
				<flow-ref doc:name="employees-scheduling-batch" doc:id="a27d9099-357a-4c0d-9fb4-7a8cadc022ee" name="employees-scheduling-batch" />
			</when>
			<otherwise >
				<logger level="INFO" doc:name="Logger Empty" doc:id="6ff96a20-4341-4f86-97db-ff296bea54c6" message="Não foi encontrado nenhum agendamento de consultor(a) criado ou alterado no Dealernet"/>
			</otherwise>
		</choice>
	</sub-flow>
	<sub-flow name="scheduled-productive-subFlow" doc:id="23005550-eb5f-4bf1-bf7f-6e97cd4a89a8" >
		<ee:transform doc:name="Variables to Get Mechanics Scheduliing and recordType" doc:id="65e8e8c8-2c31-4114-802a-b6f4dfa65c56">
			<ee:message />
			<ee:variables>
				<ee:set-variable variableName="department"><![CDATA[%dw 2.0
output application/json
---
"mechanic"]]></ee:set-variable>
				<ee:set-variable variableName="object"><![CDATA[%dw 2.0
output application/json
---
"scheduling__c"]]></ee:set-variable>
				<ee:set-variable variableName="name"><![CDATA[%dw 2.0
output application/json
