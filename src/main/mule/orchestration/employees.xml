						<ee:transform doc:name="Aggregate Payload" doc:id="5212198a-a38c-45fc-9fc1-ba0a622a3bb2" >
							<ee:message >
								<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
{
	allOrNone: "false",
	records: payload
}]]></ee:set-payload>
							</ee:message>
							<ee:variables >
								<ee:set-variable variableName="sellerCode" ><![CDATA[%dw 2.0
