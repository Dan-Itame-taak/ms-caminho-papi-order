						<flow-ref doc:name="send-employees-schedulling" doc:id="a8fd60b9-168b-4173-bfac-58cfa5a8c386" name="send-employees-schedulling"/>
						<logger level="INFO" doc:name="Logger" doc:id="d32feb76-6b65-49d2-b09e-d8605cf87267" message="#[%dw 2.0&#10;output application/json&#10;---&#10;payload map (value, index) -&gt; if(value.success == true)&#10;{&#10;    idFuncionario: vars.sellerCode[(index)],&#10;    sfId: value.id&#10;}&#10;else &#10;{&#10;    idFuncionario: vars.sellerCode[(index)],&#10;    description: value.errors[0].message&#10;}]"/>
					</batch:aggregator>
				</batch:step>
			</batch:process-records>
		</batch:job>
	</flow>
</mule>
